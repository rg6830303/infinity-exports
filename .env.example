# ---------------------------------------------------------------------------
# Infinity Exports — environment variables
# Copy this file to .env.local for local development, and add the same keys in
# your Vercel project (Settings → Environment Variables) for production.
# ---------------------------------------------------------------------------

# Web3Forms access key — powers the buyer requirement / contact forms.
# Get a free key at https://web3forms.com (see docs/WEB3FORMS_SETUP.md).
# Until a real key is set, form submissions return an error state by design.
NEXT_PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key
